# OpenProject OAuth integration via NextAuth (Auth.js v5).
#
# This frontend signs each user into OpenProject via OAuth 2.0
# (Authorization Code + PKCE). OpenProject is the backend / identity provider.
#
# One-time admin setup in OpenProject:
#   Administration → Authentication → OAuth applications → Add
#     Name:         Jira-Theme Frontend
#     Redirect URI: <AUTH_URL>/api/auth/callback/openproject
#     Confidential: yes
#     Scopes:       api_v3
#   Save, then copy the Client ID / Client Secret here.

# Single source for the upstream OpenProject URL — read on both server
# (OAuth + API client) and client (account page deep-link). The server
# reads `process.env` directly; the client receives the value via React
# context (see `lib/public-config.js` + `components/config-provider.jsx`)
# so the same Docker image can be deployed across environments.
OPENPROJECT_URL=https://openproject.example.com
OPENPROJECT_OAUTH_CLIENT_ID=
OPENPROJECT_OAUTH_CLIENT_SECRET=

# Public origin (NextAuth auto-detects in dev, but explicit is safer).
AUTH_URL=http://localhost:3000

# 32+ char secret used to sign NextAuth JWT cookies.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Which field carries story points on your work packages.
# Accepts either a top-level numeric field (e.g. "storyPoints") or a HAL link
# field whose .title is the value (e.g. "customField7" for a CustomOption like
# Size: S/M/L/XL — t-shirt values get auto-mapped to Fibonacci numbers).
# Read at request time on the server, surfaced to the client via React context.
OPENPROJECT_STORY_POINTS_FIELD=storyPoints

# Optional. Comma/space-separated three-letter day prefixes that count as
# working days for burndown / capacity charts. Defaults to Mon..Fri.
# Examples: "Mon,Tue,Wed,Thu,Fri" or "mon tue wed thu fri sat".
# OPENPROJECT_WORKING_DAYS=Mon,Tue,Wed,Thu,Fri

# Optional. Hours-per-story-point multiplier for the capacity calculation.
# Numeric. If unset, capacity calculation falls back to its default heuristic.
# HOURS_PER_POINT=8

# ─── Data source ────────────────────────────────────────────────────────────
# Pick how Opira talks to OpenProject:
#   "api"    (default) — every read AND every write goes through the OP
#                        v3 HAL+JSON API. Safest. Slower on large reads.
#   "hybrid" (recommended) — DB-direct reads (joinable, fast on big projects)
#                        + API-routed writes. Writes still produce journals,
#                        notifications, parent progress, and webhooks the
#                        same way as "api" mode. Requires OPENPROJECT_DB_URL.
# See docs/data-layer.md.
OPIRA_DATA_SOURCE=api

# Required when OPIRA_DATA_SOURCE=hybrid. Connection string for OpenProject's
# Postgres. Server-only; never commit a real value, never expose to the
# browser. Rotate immediately if it leaks (chat, screen-share, logs).
#
# STRONGLY RECOMMENDED: create a dedicated read-only user instead of
# reusing OP's writable role. Opira never writes to the DB in hybrid mode,
# so a SELECT-only grant bounds the blast radius of any future bug or
# credential leak:
#
#   CREATE USER opira_reader WITH PASSWORD '...';
#   GRANT CONNECT ON DATABASE openproject TO opira_reader;
#   GRANT USAGE ON SCHEMA public TO opira_reader;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO opira_reader;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public
#     GRANT SELECT ON TABLES TO opira_reader;
#
# Append `?sslmode=require` (or stricter) when the link traverses any
# untrusted network. Without it, pg connects in plaintext.
# Example: postgres://opira_reader:secret@db.internal:5432/openproject?sslmode=require
# OPENPROJECT_DB_URL=

# Optional. SSL mode for the OP DB connection.
#   "require" / "verify-full" — TLS with `rejectUnauthorized: true`.
#   "disable"                 — explicit plaintext (default).
#   "relax"                   — TLS with self-signed certs accepted.
#                                LAST RESORT — fix the cert chain instead.
# When unset, pg follows whatever `?sslmode=` is on the URL, otherwise
# plaintext. Use this env when you can't modify the URL.
# OPENPROJECT_DB_SSL=require

# Optional. Max connections this Next.js process holds open to the OP DB.
# Default 10 — covers a busy dev session (board + backlog + reports open
# in tabs) without crowding OP's own Rails workers. Raise only if you've
# also raised PG's `max_connections` to match.
# OPENPROJECT_DB_POOL_MAX=10

# Optional. Connection string for the test Postgres used by the schema canary
# and integration tests in `lib/data/db/*.test.js`. Skipped when unset.
# OPIRA_TEST_DB_URL=

# ─── Redis (optional) ───────────────────────────────────────────────────────
# Powers two independent subsystems:
#
# 1. Server-side cache (multi-layer L1 in-process → L2 Redis)
#    All reference data is cached to minimise OpenProject API fan-out on cold
#    page loads and pod restarts. Without Redis the in-process Map still de-
#    duplicates within a single pod's lifetime; with Redis the cache survives
#    restarts and is shared across pods.
#
#    Key namespaces and TTLs:
#      opira:lookups:*    — statuses, types, priorities, roles,
#                           time-entry activities, schemas, custom options  (7–30 days)
#      opira:sprints:*    — versions/sprints per project                   (30 min, invalidated on mutations)
#      opira:perms:*      — effective permissions per user                 (1 day,  invalidated on refresh)
#      opira:assignees:*  — available assignees per project                (15 min, invalidated on membership mutations)
#      opira:categories:* — categories per project                         (1 day,  invalidated on mutations)
#
#    Flush everything: DELETE /api/openproject/lookups/cache
#    (also the "Refresh data" button on the account page)
#
# 2. Planning poker rooms (lib/poker/)
#    Backs the live voting room in the task drawer.
#
#      unset — in-memory Map per process; 30-min idle eviction; lost on
#              restart; single pod only (replicas don't share rooms).
#      set   — Redis-backed; whole-room JSON blob at
#              opira:poker:room:{roomId} with a 30-min TTL refreshed on
#              every write; pub/sub fans state changes across pods.
#
#    If set but Redis is unreachable, SSE/POST routes return 503 and the UI
#    shows "Room offline" — the regular t-shirt picker still works.
#
# Server-only. Never log, never commit a real value.
# Example: redis://redis:6379  (or rediss://... for TLS)
# OPIRA_REDIS_URL=

# ─── AI Assist (optional) ───────────────────────────────────────────────────
# Powers the "Suggest description" button in the task create modal and task
# detail editor. When unset, the button is hidden entirely.
#
# Local Ollama (no API key needed — install from https://ollama.com):
#   OLLAMA_BASE_URL=http://localhost:11434
#   Then pull a model: ollama pull llama3.2
#
# Ollama Cloud (https://ollama.com hosted API — requires an API key):
#   OLLAMA_BASE_URL=https://ollama.com
#   OLLAMA_API_KEY=<key from https://ollama.com/settings/keys>
#
# Model to use (any model you have pulled / have access to):
#   OLLAMA_MODEL=llama3.2
#
# Server-only. Never expose to the browser. Never commit a real API key.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_MODEL=llama3.2
